    "type": "multiple-choice",
    "content": {
      "text": "จงหาดีเทอร์มิแนนต์ของเมทริกซ์ $A = \\begin{pmatrix} 1 & 2 \\\\ 3 & 4 \\end{pmatrix}$",
      "choices": {
        "a": "2",
        "b": "-2",
        "c": "10",
        "d": "-4",
        "e": "4"
      }
    },
    "answer": "b",
    "hint": "$\\det\\begin{pmatrix} a & b \\\\ c & d \\end{pmatrix} = ad - bc$",
    "solution": {
      "steps": [
        "$\\det(A) = (1)(4) - (2)(3)$",
        "$= 4 - 6 = -2$"
      ],
      "keyFormula": "$\\det\\begin{pmatrix} a & b \\\\ c & d \\end{pmatrix} = ad - bc$"
    },
    "tags": ["determinant", "2x2-matrix"],
    "source": "ONET 2566"
  },
