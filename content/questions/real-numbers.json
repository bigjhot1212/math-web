[
  {
    "id": "alg-001",
    "topicId": "real-numbers",
    "subtopic": "quadratic-equation",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "สมการ $x^2 - 5x + 6 = 0$ มีคำตอบคือข้อใด",
      "choices": {
        "a": "$x = 1, x = 6$",
        "b": "$x = 2, x = 3$",
        "c": "$x = -2, x = -3$",
        "d": "$x = 1, x = -6$",
        "e": "$x = -1, x = 6$"
      }
    },
    "answer": "b",
    "hint": "ลองแยกตัวประกอบดูครับ หาสองจำนวนที่คูณกันได้ 6 และบวกกันได้ -5",
    "solution": {
      "steps": [
        "แยกตัวประกอบ: $x^2 - 5x + 6 = (x-2)(x-3) = 0$",
        "ดังนั้น $x - 2 = 0$ หรือ $x - 3 = 0$",
        "คำตอบคือ $x = 2$ หรือ $x = 3$"
      ],
      "keyFormula": "$(x-2)(x-3) = x^2 - 5x + 6$"
    },
    "tags": ["factoring", "quadratic"],
    "source": "ONET 2566"
  },
  {
    "id": "alg-002",
    "topicId": "real-numbers",
    "subtopic": "quadratic-equation",
    "level": "ONET",
    "difficulty": "medium",
    "type": "multiple-choice",
    "content": {
      "text": "ถ้า $x^2 - 4 = 0$ แล้วค่าของ $x^2 + x$ เท่ากับเท่าใด เมื่อ $x > 0$",
      "choices": {
        "a": "$4$",
        "b": "$6$",
        "c": "$8$",
        "d": "$2$",
        "e": "$10$"
      }
    },
    "answer": "b",
    "hint": "หาค่า x ก่อน แล้วค่อยแทนใน $x^2 + x$",
    "solution": {
      "steps": [
        "$x^2 - 4 = 0$ ดังนั้น $x^2 = 4$",
        "เนื่องจาก $x > 0$ จะได้ $x = 2$",
        "แทนค่า: $x^2 + x = 4 + 2 = 6$"
      ],
      "keyFormula": "$x^2 = 4 \\Rightarrow x = \\pm 2$"
    },
    "tags": ["quadratic", "substitution"],
    "source": "ONET 2566"
  },
  {
    "id": "alg-003",
