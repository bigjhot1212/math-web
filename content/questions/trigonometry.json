    "type": "multiple-choice",
    "content": {
      "text": "$\\sin 30°$ มีค่าเท่าใด",
      "choices": {
        "a": "$\\dfrac{1}{2}$",
        "b": "$\\dfrac{\\sqrt{3}}{2}$",
        "c": "$1$",
        "d": "$\\dfrac{\\sqrt{2}}{2}$",
        "e": "$0$"
      }
    },
    "answer": "a",
    "hint": "จำค่าตรีโกณมิติของมุมพิเศษ 30°, 45°, 60°",
    "solution": {
      "steps": [
        "จากตารางค่าตรีโกณมิติมุมพิเศษ",
        "$\\sin 30° = \\dfrac{1}{2}$"
      ],
      "keyFormula": "$\\sin 30° = \\dfrac{1}{2}$, $\\cos 30° = \\dfrac{\\sqrt{3}}{2}$, $\\tan 30° = \\dfrac{1}{\\sqrt{3}}$"
    },
    "tags": ["special-angles", "sine"],
    "source": "ONET 2566"
  },
  {
