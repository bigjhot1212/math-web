    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "กำหนดให้ $f(x) = 2x + 3$ จงหาค่า $f(4)$",
      "choices": {
        "a": "8",
        "b": "10",
        "c": "11",
        "d": "14",
        "e": "9"
      }
    },
    "answer": "c",
    "hint": "แทนค่า $x = 4$ ลงในสูตร",
    "solution": {
      "steps": [
        "แทนค่า $x = 4$ ลงใน $f(x) = 2x + 3$",
        "$f(4) = 2(4) + 3 = 8 + 3 = 11$"
      ]
    },
    "tags": ["function-evaluation"],
    "source": "ONET 2566"
  },
  {
    "id": "rf-002",
    "topicId": "relations-functions",
