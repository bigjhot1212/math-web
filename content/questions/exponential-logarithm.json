    "type": "multiple-choice",
    "content": {
      "text": "ถ้า $\\log_3 5 = a$ แล้ว $\\log_9 25$ มีค่าเท่าใด",
      "choices": {
        "a": "$2a$",
        "b": "$a^2$",
        "c": "$a$",
        "d": "$\\dfrac{a}{2}$",
        "e": "$\\dfrac{2}{a}$"
      }
    },
    "answer": "c",
    "hint": "แปลงฐาน: $\\log_9 25 = \\dfrac{\\log_3 25}{\\log_3 9}$",
    "solution": {
      "steps": [
        "$\\log_9 25 = \\dfrac{\\log_3 25}{\\log_3 9}$",
        "$\\log_3 25 = \\log_3 5^2 = 2\\log_3 5 = 2a$",
        "$\\log_3 9 = \\log_3 3^2 = 2$",
        "$\\log_9 25 = \\dfrac{2a}{2} = a$"
      ],
      "keyFormula": "$\\log_b x = \\dfrac{\\log_c x}{\\log_c b}$"
    },
    "tags": ["change-of-base"],
    "source": "PAT1 2566"
