    "subtopic": "exponential-equations",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "จงแก้สมการ $2^x = 32$",
      "choices": {
        "a": "$x = 4$",
        "b": "$x = 5$",
        "c": "$x = 6$",
        "d": "$x = 3$",
        "e": "$x = 16$"
      }
    },
    "answer": "b",
    "hint": "เขียน 32 ในรูปเลขยกกำลังฐาน 2",
    "solution": {
      "steps": [
        "$2^x = 32$",
        "$32 = 2^5$",
        "ดังนั้น $2^x = 2^5$",
        "$x = 5$"
      ]
    },
    "tags": ["exponential-equations"],
    "source": "ONET 2566"
