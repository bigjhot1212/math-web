[
  {
    "id": "cal-001",
    "topicId": "calculus",
    "subtopic": "limits",
    "level": "ONET",
    "difficulty": "medium",
    "type": "multiple-choice",
    "content": {
      "text": "จงหา $\\lim_{x \\to 2} \\dfrac{x^2 - 4}{x - 2}$",
      "choices": {
        "a": "0",
        "b": "2",
        "c": "4",
        "d": "ไม่มีลิมิต",
        "e": "1"
      }
    },
    "answer": "c",
    "hint": "แยกตัวประกอบตัวเศษก่อน",
    "solution": {
      "steps": [
        "$\\lim_{x \\to 2} \\dfrac{x^2 - 4}{x - 2} = \\lim_{x \\to 2} \\dfrac{(x-2)(x+2)}{x-2}$",
        "$= \\lim_{x \\to 2} (x + 2)$",
        "$= 2 + 2 = 4$"
      ]
    },
    "tags": ["limits", "factoring"],
    "source": "ONET 2566"
  },
  {
