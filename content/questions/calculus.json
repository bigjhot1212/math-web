  {
    "id": "cal-004",
    "topicId": "calculus",
    "subtopic": "integration",
    "level": "A-Level",
    "difficulty": "medium",
    "type": "multiple-choice",
    "content": {
      "text": "$\\int 3x^2 \\, dx$ มีค่าเท่าใด",
      "choices": {
        "a": "$6x + C$",
        "b": "$x^3 + C$",
        "c": "$3x^3 + C$",
        "d": "$\\dfrac{3x^2}{2} + C$",
        "e": "$9x + C$"
      }
    },
    "answer": "b",
    "hint": "ใช้กฎกำลัง $\\int x^n dx = \\dfrac{x^{n+1}}{n+1} + C$",
    "solution": {
      "steps": [
        "$\\int 3x^2 \\, dx = 3 \\cdot \\dfrac{x^{2+1}}{2+1} + C$",
        "$= 3 \\cdot \\dfrac{x^3}{3} + C = x^3 + C$"
      ],
      "keyFormula": "$\\int x^n \\, dx = \\dfrac{x^{n+1}}{n+1} + C$"
    },
    "tags": ["integration", "power-rule"],
    "source": "A-Level 2566"
  },
  {
    "id": "cal-005",
    "topicId": "calculus",
    "subtopic": "definite-integral",
    "level": "A-Level",
    "difficulty": "medium",
    "type": "multiple-choice",
    "content": {
      "text": "จงหา $\\int_0^2 (2x + 1) \\, dx$",
      "choices": {
        "a": "4",
        "b": "5",
        "c": "6",
        "d": "8",
        "e": "3"
      }
    },
    "answer": "c",
    "hint": "หาปฏิยานุพันธ์ก่อน แล้วแทนค่าขอบเขต",
    "solution": {
      "steps": [
        "$\\int_0^2 (2x+1) \\, dx = \\left[x^2 + x\\right]_0^2$",
        "$= (4 + 2) - (0 + 0) = 6$"
      ]
    },
    "tags": ["definite-integral"],
    "source": "A-Level 2566"
  }
]
