    "type": "multiple-choice",
    "content": {
      "text": "อนุพันธ์ของ $f(x) = x^4$ คือข้อใด",
      "choices": {
        "a": "$x^3$",
        "b": "$4x^3$",
        "c": "$4x^4$",
        "d": "$\\dfrac{x^5}{5}$",
        "e": "$4x^5$"
      }
    },
    "answer": "b",
    "hint": "ใช้กฎกำลัง $\\dfrac{d}{dx}(x^n) = nx^{n-1}$",
    "solution": {
      "steps": [
        "ใช้กฎกำลัง: $\\dfrac{d}{dx}(x^n) = nx^{n-1}$",
        "$f'(x) = 4x^{4-1} = 4x^3$"
      ],
      "keyFormula": "$\\dfrac{d}{dx}(x^n) = nx^{n-1}$"
    },
    "tags": ["derivatives", "power-rule"],
    "source": "ONET 2566"
  },
