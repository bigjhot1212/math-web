    "type": "multiple-choice",
    "content": {
      "text": "ฐานนิยมของข้อมูล $\\{3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5\\}$ คือเท่าใด",
      "choices": {
        "a": "1",
        "b": "3",
        "c": "9",
        "d": "5",
        "e": "4"
      }
    },
    "answer": "d",
    "hint": "ฐานนิยมคือค่าที่ปรากฏบ่อยที่สุด",
    "solution": {
      "steps": [
        "นับความถี่: 1→2, 2→1, 3→2, 4→1, 5→3, 6→1, 9→1",
        "5 ปรากฏ 3 ครั้ง มากที่สุด",
        "ฐานนิยม = 5"
      ]
    },
    "tags": ["mode"],
