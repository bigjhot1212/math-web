[
  {
    "id": "stat-001",
    "topicId": "statistics-distributions",
    "subtopic": "mean",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "ค่าเฉลี่ยเลขคณิตของข้อมูล $\\{4, 8, 6, 2, 10\\}$ คือเท่าใด",
      "choices": {
        "a": "5",
        "b": "7",
        "c": "6",
        "d": "8",
        "e": "4"
      }
    },
    "answer": "c",
    "hint": "บวกทุกค่าแล้วหารด้วยจำนวนข้อมูล",
    "solution": {
      "steps": [
        "ผลรวม $= 4 + 8 + 6 + 2 + 10 = 30$",
        "จำนวนข้อมูล $= 5$",
        "ค่าเฉลี่ย $= \\dfrac{30}{5} = 6$"
      ],
      "keyFormula": "$\\bar{x} = \\dfrac{\\sum x_i}{n}$"
    },
    "tags": ["mean"],
    "source": "ONET 2566"
  },
  {
    "id": "stat-002",
    "topicId": "statistics-distributions",
    "subtopic": "median",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "มัธยฐานของข้อมูล $\\{7, 2, 9, 4, 5, 1, 8\\}$ คือเท่าใด",
      "choices": {
        "a": "4",
        "b": "9",
        "c": "5",
        "d": "7",
        "e": "6"
      }
    },
    "answer": "c",
    "hint": "เรียงข้อมูลจากน้อยไปมาก แล้วหาค่ากลาง",
    "solution": {
      "steps": [
        "เรียงข้อมูล: $1, 2, 4, 5, 7, 8, 9$",
        "จำนวนข้อมูล = 7 (คี่)",
        "มัธยฐาน = ค่าตำแหน่งที่ $(7+1)/2 = 4$",
        "ค่าตำแหน่งที่ 4 = 5"
      ]
    },
    "tags": ["median"],
    "source": "ONET 2566"
  },
  {
    "id": "stat-003",
