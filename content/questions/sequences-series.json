[
  {
    "id": "seq-001",
    "topicId": "sequences-series",
    "subtopic": "arithmetic-sequence",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "ลำดับเลขคณิต $2, 5, 8, 11, \\ldots$ พจน์ที่ 10 มีค่าเท่าใด",
      "choices": {
        "a": "26",
        "b": "28",
        "c": "29",
        "d": "30",
        "e": "32"
      }
    },
    "answer": "c",
    "hint": "สูตรพจน์ทั่วไปของลำดับเลขคณิต $a_n = a_1 + (n-1)d$",
    "solution": {
      "steps": [
        "$a_1 = 2$, $d = 5 - 2 = 3$",
        "$a_{10} = 2 + (10-1)(3) = 2 + 27 = 29$"
      ],
      "keyFormula": "$a_n = a_1 + (n-1)d$"
    },
    "tags": ["arithmetic-sequence"],
    "source": "ONET 2566"
  },
  {
    "id": "seq-002",
    "topicId": "sequences-series",
    "subtopic": "arithmetic-series",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "$1 + 2 + 3 + \\cdots + 20$ มีค่าเท่าใด",
      "choices": {
        "a": "190",
        "b": "200",
        "c": "210",
        "d": "220",
        "e": "180"
      }
    },
    "answer": "c",
    "hint": "ใช้สูตร $S_n = \\dfrac{n(a_1 + a_n)}{2}$",
    "solution": {
      "steps": [
        "$S_{20} = \\dfrac{20(1 + 20)}{2} = \\dfrac{20 \\times 21}{2} = 210$"
      ],
      "keyFormula": "$S_n = \\dfrac{n(a_1 + a_n)}{2}$"
    },
    "tags": ["arithmetic-series"],
    "source": "ONET 2565"
  },
  {
    "id": "seq-003",
    "topicId": "sequences-series",
    "subtopic": "geometric-sequence",
    "level": "ONET",
    "difficulty": "easy",
    "type": "multiple-choice",
    "content": {
      "text": "ลำดับเรขาคณิต $3, 6, 12, 24, \\ldots$ มีอัตราส่วนร่วมเท่าใด",
      "choices": {
        "a": "3",
        "b": "6",
        "c": "2",
        "d": "4",
        "e": "12"
      }
    },
    "answer": "c",
    "hint": "อัตราส่วนร่วม $r = \\dfrac{a_{n+1}}{a_n}$",
    "solution": {
      "steps": [
        "$r = \\dfrac{6}{3} = 2$",
        "ตรวจสอบ: $\\dfrac{12}{6} = 2$, $\\dfrac{24}{12} = 2$ ✓"
      ],
      "keyFormula": "$r = \\dfrac{a_{n+1}}{a_n}$"
    },
    "tags": ["geometric-sequence", "common-ratio"],
    "source": "ONET 2566"
  },
  {
    "id": "seq-004",
    "topicId": "sequences-series",
    "subtopic": "infinite-geometric-series",
    "level": "A-Level",
    "difficulty": "medium",
    "type": "multiple-choice",
    "content": {
      "text": "ผลบวกของอนุกรมเรขาคณิตอนันต์ $1 + \\dfrac{1}{2} + \\dfrac{1}{4} + \\dfrac{1}{8} + \\cdots$ มีค่าเท่าใด",
      "choices": {
        "a": "$\\dfrac{3}{2}$",
        "b": "$\\dfrac{1}{2}$",
        "c": "$3$",
        "d": "$2$",
        "e": "ผลบวกไม่มีจำกัด"
      }
    },
    "answer": "d",
    "hint": "$S_\\infty = \\dfrac{a_1}{1-r}$ เมื่อ $|r| < 1$",
    "solution": {
      "steps": [
        "$a_1 = 1$, $r = \\dfrac{1}{2}$",
        "เนื่องจาก $|r| = \\dfrac{1}{2} < 1$ อนุกรมนี้มีผลบวก",
        "$S_\\infty = \\dfrac{1}{1 - \\frac{1}{2}} = \\dfrac{1}{\\frac{1}{2}} = 2$"
      ],
      "keyFormula": "$S_\\infty = \\dfrac{a_1}{1-r}, \\quad |r| < 1$"
    },
    "tags": ["infinite-series", "geometric-series"],
    "source": "A-Level 2566"
  },
  {
    "id": "seq-005",
    "topicId": "sequences-series",
    "subtopic": "geometric-series",
    "level": "A-Level",
    "difficulty": "medium",
    "type": "multiple-choice",
    "content": {
      "text": "ผลบวก 5 พจน์แรกของอนุกรมเรขาคณิตที่มี $a_1 = 2$ และ $r = 3$ มีค่าเท่าใด",
      "choices": {
        "a": "242",
        "b": "243",
        "c": "240",
        "d": "244",
        "e": "248"
      }
    },
    "answer": "a",
    "hint": "$S_n = a_1 \\cdot \\dfrac{r^n - 1}{r - 1}$ เมื่อ $r \\neq 1$",
    "solution": {
      "steps": [
        "$S_5 = 2 \\cdot \\dfrac{3^5 - 1}{3 - 1}$",
        "$= 2 \\cdot \\dfrac{243 - 1}{2}$",
        "$= 2 \\cdot \\dfrac{242}{2} = 242$"
      ],
      "keyFormula": "$S_n = \\dfrac{a_1(r^n-1)}{r-1}$"
    },
    "tags": ["geometric-series"],
    "source": "A-Level 2565"
  }
]
